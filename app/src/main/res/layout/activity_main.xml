<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E1">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        tools:ignore="MissingClass">

        <!-- Product Image Container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/imageCard"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/productImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#FFF3E0"
                android:padding="40dp"
                android:scaleType="centerInside"
                android:src="@drawable/turmeric"
                tools:ignore="ContentDescription"
                tools:src="@drawable/chatgpt_image_mar_8__2026__12_55_35_pm" />
        </androidx.cardview.widget.CardView>

        <!-- Product Title -->
        <TextView
            android:id="@+id/productTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Turmeric (Haldi)"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/imageCard"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Product Price -->
        <TextView
            android:id="@+id/productPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹150.00"
            android:textSize="22sp"
            android:textColor="#5D4037"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/productTitle"
            app:layout_constraintBottom_toBottomOf="@id/productTitle"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Description -->
        <TextView
            android:id="@+id/description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pure organic turmeric powder sourced from Erode, Tamil Nadu. Known for its high curcumin content and medicinal properties. Perfect for authentic Indian cooking."
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="16dp"
            android:textColor="#5D4037"
            app:layout_constraintTop_toBottomOf="@id/productTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Delivery Info -->
        <TextView
            android:id="@+id/deliveryInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delivery: 2-4 Business Days"
            android:layout_marginTop="16dp"
            android:drawableStart="@android:drawable/ic_menu_today"
            android:drawablePadding="8dp"
            android:textColor="#E64A19"
            app:layout_constraintTop_toBottomOf="@id/description"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Add To Cart Button -->
        <Button
            android:id="@+id/addToCartBtn"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="ADD TO CART"
            android:backgroundTint="#FFC107"
            android:textColor="#000000"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/deliveryInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/buyNowBtn"
            app:layout_constraintHorizontal_weight="1"/>

        <!-- Buy Now Button -->
        <Button
            android:id="@+id/buyNowBtn"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="BUY NOW"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="@id/addToCartBtn"
            app:layout_constraintStart_toEndOf="@id/addToCartBtn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
